{
  "hosting": [
    {
      "target": "homelibrary",
      "public": "public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "**", "function": "nextServer" }
      ]
    }
  ],
  "functions": {
    "source": "functions"
  },
  "predeploy": ["npm run build"]
}
